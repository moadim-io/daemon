{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:api": "openapi-typescript ../apis/openapi.json -o src/api/schema.gen.ts",
    "build": "pnpm run generate:api && tsc --noEmit && vite build",
    "dev": "pnpm run generate:api && vite",
    "preview": "vite preview",
    "pretypecheck": "pnpm run generate:api",
    "typecheck": "tsc --noEmit",
    "prelint": "pnpm run generate:api",
    "lint": "eslint .",
    "pretest": "pnpm run generate:api",
    "test": "vitest run",
    "pretest:coverage": "pnpm run generate:api",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "cron-parser": "^5.6.2",
    "cronstrue": "^3.0.0",
    "openapi-fetch": "^0.17.0",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^7.18.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.5.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.5",
    "vite-plugin-singlefile": "^2.1.0",
    "vitest": "^4.1.10"
  }
}
